generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── AUTH ────────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         Role     @default(TRAINEE)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  traineeProfile TraineeProfile?
  invitesSent    InviteCode[]    @relation("SentBy")
}

enum Role {
  ADMIN
  TRAINEE
}

model InviteCode {
  id          String    @id @default(cuid())
  code        String    @unique @default(cuid())
  email       String?
  used        Boolean   @default(false)
  usedAt      DateTime?
  createdAt   DateTime  @default(now())
  expiresAt   DateTime?
  createdById String
  createdBy   User      @relation("SentBy", fields: [createdById], references: [id])
}

// ─── TRAINEE PROFILE ─────────────────────────────────────────────────────────

model TraineeProfile {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id])
  firstName    String
  lastName     String
  phone        String?
  dateOfBirth  DateTime?
  gender       String?
  profilePhoto String?
  heightCm     Float?
  startWeight  Float?
  goal         String?
  notes        String?
  isActive     Boolean  @default(true)
  joinedAt     DateTime @default(now())

  measurements      BodyMeasurement[]
  progressPhotos    ProgressPhoto[]
  assignedPrograms  ProgramAssignment[]
  assignedDietPlans DietPlanAssignment[]
  checkIns          CheckIn[]
  comments          Comment[]
}

// ─── BODY MEASUREMENTS ───────────────────────────────────────────────────────

model BodyMeasurement {
  id            String         @id @default(cuid())
  traineeId     String
  trainee       TraineeProfile @relation(fields: [traineeId], references: [id])
  recordedAt    DateTime       @default(now())
  weightKg      Float?
  bodyFatPct    Float?
  muscleMassPct Float?
  chest         Float?
  waist         Float?
  hips          Float?
  leftArm       Float?
  rightArm      Float?
  leftThigh     Float?
  rightThigh    Float?
  shoulders     Float?
  neck          Float?
  bmi           Float?
  bmr           Float?
  whr           Float?
  notes         String?
}

// ─── PROGRESS PHOTOS ─────────────────────────────────────────────────────────

model ProgressPhoto {
  id        String         @id @default(cuid())
  traineeId String
  trainee   TraineeProfile @relation(fields: [traineeId], references: [id])
  filePath  String
  angle     PhotoAngle?
  takenAt   DateTime       @default(now())
  notes     String?
}

enum PhotoAngle {
  FRONT
  BACK
  LEFT
  RIGHT
}

// ─── EXERCISE LIBRARY ────────────────────────────────────────────────────────

model Exercise {
  id               String            @id @default(cuid())
  name             String
  description      String?
  category         String?
  muscleGroups     String[]
  equipment        String?
  videoUrl         String?
  instructions     String?
  createdAt        DateTime          @default(now())
  workoutExercises WorkoutExercise[]
}

// ─── WORKOUT PROGRAMS ────────────────────────────────────────────────────────

model WorkoutProgram {
  id            String          @id @default(cuid())
  name          String
  description   String?
  mode          ProgramMode     @default(SIMPLE)
  durationWeeks Int?
  isTemplate    Boolean         @default(false)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  phases        ProgramPhase[]
  assignments   ProgramAssignment[]
}

enum ProgramMode {
  SIMPLE
  DETAILED
}

model ProgramPhase {
  id          String         @id @default(cuid())
  programId   String
  program     WorkoutProgram @relation(fields: [programId], references: [id], onDelete: Cascade)
  name        String
  order       Int
  weeks       WorkoutWeek[]
  workoutDays WorkoutDay[]
}

model WorkoutWeek {
  id         String       @id @default(cuid())
  phaseId    String
  phase      ProgramPhase @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  weekNumber Int
  days       WorkoutDay[]
}

model WorkoutDay {
  id        String        @id @default(cuid())
  phaseId   String?
  phase     ProgramPhase? @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  weekId    String?
  week      WorkoutWeek?  @relation(fields: [weekId], references: [id], onDelete: Cascade)
  dayLabel  String
  order     Int
  notes     String?
  exercises WorkoutExercise[]
}

model WorkoutExercise {
  id         String   @id @default(cuid())
  dayId      String
  day        WorkoutDay @relation(fields: [dayId], references: [id], onDelete: Cascade)
  exerciseId String
  exercise   Exercise @relation(fields: [exerciseId], references: [id])
  order      Int
  sets       Int?
  reps       String?
  restSeconds Int?
  tempo      String?
  notes      String?
  rpe        Float?
}

model ProgramAssignment {
  id         String         @id @default(cuid())
  traineeId  String
  trainee    TraineeProfile @relation(fields: [traineeId], references: [id])
  programId  String
  program    WorkoutProgram @relation(fields: [programId], references: [id])
  startDate  DateTime?
  endDate    DateTime?
  isActive   Boolean        @default(true)
  assignedAt DateTime       @default(now())
  notes      String?
}

// ─── DIET PLANS ──────────────────────────────────────────────────────────────

model DietPlan {
  id             String              @id @default(cuid())
  name           String
  description    String?
  targetCalories Int?
  proteinG       Int?
  carbsG         Int?
  fatsG          Int?
  isTemplate     Boolean             @default(false)
  createdAt      DateTime            @default(now())
  meals          Meal[]
  assignments    DietPlanAssignment[]
}

model Meal {
  id         String     @id @default(cuid())
  dietPlanId String
  dietPlan   DietPlan   @relation(fields: [dietPlanId], references: [id], onDelete: Cascade)
  name       String
  order      Int
  timing     String?
  calories   Int?
  notes      String?
  items      MealItem[]
}

model MealItem {
  id       String @id @default(cuid())
  mealId   String
  meal     Meal   @relation(fields: [mealId], references: [id], onDelete: Cascade)
  name     String
  amount   String?
  calories Int?
  proteinG Float?
  carbsG   Float?
  fatsG    Float?
  order    Int
}

model DietPlanAssignment {
  id         String         @id @default(cuid())
  traineeId  String
  trainee    TraineeProfile @relation(fields: [traineeId], references: [id])
  dietPlanId String
  dietPlan   DietPlan       @relation(fields: [dietPlanId], references: [id])
  startDate  DateTime?
  endDate    DateTime?
  isActive   Boolean        @default(true)
  assignedAt DateTime       @default(now())
  notes      String?
}

// ─── CHECK-INS ───────────────────────────────────────────────────────────────

model CheckIn {
  id              String         @id @default(cuid())
  traineeId       String
  trainee         TraineeProfile @relation(fields: [traineeId], references: [id])
  type            CheckInType
  submittedAt     DateTime       @default(now())
  sleepScore      Int?
  energyScore     Int?
  adherenceScore  Int?
  moodScore       Int?
  traineeNotes    String?
  sessionDate     DateTime?
  duration        Int?
  exercisesLog    String?
  trainerNotes    String?
  trainerReview   String?
  reviewedAt      DateTime?
}

enum CheckInType {
  SELF_REPORT
  SESSION_LOG
}

// ─── COMMENTS ────────────────────────────────────────────────────────────────

model Comment {
  id        String         @id @default(cuid())
  traineeId String
  trainee   TraineeProfile @relation(fields: [traineeId], references: [id])
  context   CommentContext
  contextId String?
  content   String
  isPrivate Boolean        @default(false)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

enum CommentContext {
  PROGRAM
  DIET
  CHECKIN
  GENERAL
}

// ─── CALCULATION HISTORY ─────────────────────────────────────────────────────

model CalculationRecord {
  id        String   @id @default(cuid())
  traineeId String?
  type      CalcType
  inputs    Json
  results   Json
  createdAt DateTime @default(now())
}

enum CalcType {
  BMI
  BMR
  WHR
  BODY_FAT
  IDEAL_WEIGHT
  ONE_REP_MAX
  MACRO
  WATER_INTAKE
  TDEE
}